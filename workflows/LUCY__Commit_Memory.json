{
  "name": "LUCY - Commit Memory",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "lucy/commit",
        "responseMode": "lastNode",
        "responseCode": 200,
        "options": {}
      },
      "id": "lucy-commit-webhook",
      "name": "Commit Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "webhookId": "lucy-commit-memory",
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://172.17.0.1:6970/commit",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.body }}",
        "options": {}
      },
      "id": "lucy-commit-memory-gateway",
      "name": "Write Memory Gateway",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        520,
        300
      ]
    }
  ],
  "connections": {
    "Commit Webhook": {
      "main": [
        [
          {
            "node": "Write Memory Gateway",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": false
  }
}
