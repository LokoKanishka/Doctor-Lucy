{
    "mcpServers": {
        "nin-github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "REEMPLAZAR_CON_ENV_VAR"
            }
        },
        "telegram-lucy": {
            "command": "python3",
            "args": [
                "/home/lucy-ubuntu/Escritorio/doctor de lucy/scripts/telegram_bridge.py"
            ],
            "env": {
                "TG_TOKEN": "REEMPLAZAR_CON_ENV_VAR",
                "DIEGO_ID": "REEMPLAZAR_CON_ENV_VAR"
            }
        },
        "web-search": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-web-search"
            ],
            "env": {
                "TAVILY_API_KEY": "REEMPLAZAR_CON_ENV_VAR"
            }
        },
        "nin-n8n-v3": {
            "command": "npx",
            "args": [
                "-y",
                "@n8n/mcp-server-n8n"
            ],
            "env": {
                "N8N_API_KEY": "REEMPLAZAR_CON_ENV_VAR",
                "N8N_HOST": "http://localhost:5688"
            }
        },
        "google-cloud": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-google-cloud"
            ],
            "env": {
                "GOOGLE_API_KEY": "REEMPLAZAR_CON_ENV_VAR"
            }
        },
        "health-dashboard": {
            "command": "python3",
            "args": [
                "/home/lucy-ubuntu/Escritorio/doctor de lucy/scripts/health_dashboard.py"
            ]
        },
        "youtube-mcp": {
            "command": "npx",
            "args": [
                "-y",
                "@mrsknetwork/ytmcp"
            ]
        },
        "anthropic-fetch": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-fetch"]
        },
        "anthropic-git": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-git"]
        },
        "anthropic-sequentialthinking": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-sequentialthinking"]
        },
        "anthropic-time": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-time"]
        },
        "anthropic-filesystem": {
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/lucy-ubuntu/Escritorio"]
        }
    }
}